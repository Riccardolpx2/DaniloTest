<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.TextFlow?>

<StackPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.GameController">
   <children>
      <VBox spacing="20.0" style="-fx-background-color: #2c3e50;">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label fx:id="sfidanteLabel" text="Partita contro in attesa..." textFill="WHITE">
                     <font>
                        <Font name="GFSGazis-Regular" size="24.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="timerLabel" text="00:00" textFill="#e74c3c">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <VBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <TextFlow fx:id="textFlow" prefHeight="150.0" prefWidth="500.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-padding: 10; -fx-text-alignment: center;" />
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <TextField fx:id="answerField" prefWidth="250.0" promptText="Inserisci la parola corretta..." style="-fx-background-radius: 5; -fx-padding: 10;">
                           <font>
                              <Font size="14.0" />
                           </font>
                        </TextField>
                        <Button fx:id="submitButton" mnemonicParsing="false" onAction="#submitAnswer" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Invia">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                           <padding>
                              <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                           </padding>
                        </Button>
                     </children>
                  </HBox>
                  <Label fx:id="statusLabel" textFill="WHITE">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
         </children>
      </VBox>

      <VBox fx:id="resultOverlay" alignment="CENTER" spacing="30.0" style="-fx-background-color: rgba(20, 30, 48, 0.95);" visible="false">
         <children>
            <Label fx:id="roundResultLabel" text="Risultato Round" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="38.0" />
               </font>
            </Label>

            <Label fx:id="correctWordLabel" text="La parola corretta era:" textFill="#bdc3c7">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>

            <HBox alignment="CENTER" spacing="50.0">
               <children>
                  <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: rgba(46, 204, 113, 0.15); -fx-padding: 15 30 15 30; -fx-background-radius: 10; -fx-border-color: #2ecc71; -fx-border-radius: 10; -fx-border-width: 2;">
                     <children>
                        <Label text="IL TUO PUNTEGGIO" textFill="#2ecc71">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <Label fx:id="myScoreLabel" text="0" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="36.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>

                  <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: rgba(231, 76, 60, 0.15); -fx-padding: 15 30 15 30; -fx-background-radius: 10; -fx-border-color: #e74c3c; -fx-border-radius: 10; -fx-border-width: 2;">
                     <children>
                        <Label text="AVVERSARIO" textFill="#e74c3c">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <Label fx:id="opponentScoreLabel" text="0" textFill="WHITE">
                           <font>
                              <Font name="System Bold" size="36.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox fx:id="gameEndOverlay" alignment="CENTER" spacing="40.0" style="-fx-background-color: rgba(20, 30, 48, 0.98);" visible="false">
         <children>
            <Label text="Partita Terminata" textFill="#f39c12">
               <font>
                  <Font name="System Bold" size="48.0" />
               </font>
            </Label>

            <Label fx:id="gameEndMessageLabel" text="Messaggio del server..." textFill="WHITE" wrapText="true" textAlignment="CENTER">
               <font>
                  <Font size="28.0" />
               </font>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </Label>

            <Button mnemonicParsing="false" onAction="#returnToDashboard" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Torna alla Dashboard">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <padding>
                  <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
               </padding>
            </Button>
         </children>
      </VBox>
   </children>
</StackPane>